  "accounts": {
    "enabled": true,
    "min_positions": 5,
    "min_resolved_count": 10,
    "min_win_rate": 55.0,
    "min_cash_pnl": 100.0,
    "min_pct_pnl": 10.0,
    "max_wallets_to_track": 50,
    "max_wallets_per_scan": 20,
    "cache_ttl_hours": 24,
    "discovery_sample_size": 1000,
    "watchlist": [],
    "watchlist_min_position_value": 1000,
    "watchlist_cache_ttl_hours": 4
  },
  "external_markets": {
    "enabled": true,
    "manifold_results_per_query": 8,
    "metaculus_enabled": true,
    "metaculus_results_per_query": 6,
    "odds_api_enabled": true,
    "odds_api_sports": [
      "americanfootball_nfl",
      "americanfootball_ncaaf",
      "basketball_nba",
      "basketball_ncaab",
      "baseball_mlb",
      "icehockey_nhl",
      "soccer_epl",
      "soccer_usa_mls"
    ],
    "min_match_score": 0.45,
    "min_price_gap": 0.0
