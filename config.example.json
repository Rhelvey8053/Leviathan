    "efficient_market_keywords": [
      "CPI",
      "Federal Reserve",
      "Fed rate",
      "nonfarm payroll",
      "jobs report",
      "GDP",
      "inflation rate",
      "FOMC",
      "unemployment rate",
      "interest rate decision",
      "treasury yield",
      "10-year yield",
      "S&P 500",
      "Dow Jones",
      "Nasdaq",
      "stock market close",
      "Super Bowl winner",
      "NBA Finals winner",
      "World Series winner",
      "presidential election",
      "presidential approval",
      "Bitcoin price",
      "Ethereum price",
      "crypto price",
      "oil price",
      "WTI crude",
      "brent crude",
      "gold price",
      "trade deficit",
      "current account",
      "balance of payments",
      "housing starts",
      "consumer confidence",
      "ISM manufacturing",
      "quarterly earnings",
      "EPS beat",
      "revenue beat"
