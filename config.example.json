    "lookback_trades": 100,
    "min_whale_size": 100,
    "scan_trade_limit": 500
  },
  "scoring": {
    "scorer_model": "claude-sonnet-4-6",
    "max_markets_per_run": 10,
    "confidence_threshold": "MED",
    "max_probe_markets": 10,
    "max_probe_days_to_close": 365,
    "min_high_confidence_edge": 0.1,
    "min_report_lv": 40,
    "min_pre_claude_lv": 20,
    "max_pass_before_suppress": 5,
    "resolve_first_max_days": 14,
    "resolve_first_dedup_days": 7
