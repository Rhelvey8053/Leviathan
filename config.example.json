    "min_hours_to_close": 6,
    "max_days_to_close": 180,
    "bucket_min_volume": {
      "INTRADAY": 50,
      "WEEKLY": 150,
      "MONTHLY": 400,
      "QUARTERLY": 250,
      "LONG": 100
