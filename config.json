{
  "environment": "prod",

  "markets": {
    "max_fetch": 1000,
    "max_events": 400,
    "edge_threshold": 0.08,
    "min_market_price": 0.05,
    "max_market_price": 0.95,
    "min_volume": 500,
    "max_volume_filter": 150000,
    "min_days_to_close": 0,
    "max_days_to_close": 180,
    "bucket_min_volume": {
      "INTRADAY":  50,
      "WEEKLY":    150,
      "MONTHLY":   400,
      "QUARTERLY": 250,
      "LONG":      100
    },
    "efficient_market_keywords": [
      "CPI", "Federal Reserve", "Fed rate", "nonfarm payroll",
      "jobs report", "GDP", "inflation rate", "FOMC", "unemployment rate"
    ],
    "categories": []
  },

  "whales": {
    "size_multiplier": 5,
    "volume_spike_hours": 1,
    "lookback_trades": 100
  },

  "scoring": {
    "scorer_model": "claude-sonnet-4-6",
    "support_model": "claude-haiku-4-5-20251001",
    "max_markets_per_run": 10,
    "confidence_threshold": "MED"
  },

  "accounts": {
    "enabled": true,
    "min_positions": 5,
    "min_resolved_count": 10,
    "min_win_rate": 55.0,
    "min_cash_pnl": 100.0,
    "min_pct_pnl": 10.0,
    "max_wallets_to_track": 50,
    "max_wallets_per_scan": 20,
    "cache_ttl_hours": 24,
    "discovery_sample_size": 1000
  },

  "external_markets": {
    "enabled": true,
    "manifold_results_per_query": 8,
    "metaculus_enabled": true,
    "metaculus_results_per_query": 6,
    "odds_api_enabled": true,
    "odds_api_sports": [
      "americanfootball_nfl",
      "americanfootball_ncaaf",
      "basketball_nba",
      "basketball_ncaab",
      "baseball_mlb",
      "icehockey_nhl",
      "soccer_epl",
      "soccer_usa_mls"
    ],
    "min_match_score": 0.45,
    "min_price_gap": 0.0
  },

  "polymarket": {
    "enabled": true,
    "max_fetch": 500,
    "min_match_score": 0.50,
    "min_price_gap": 0.0
  },

  "report": {
    "email_to": "your@email.com",
    "email_from": "",
    "smtp_host": "smtp.gmail.com",
    "smtp_port": 587
  }
}
